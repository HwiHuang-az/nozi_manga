// Nozi Manga - Prisma Schema (Prisma 5 + MySQL via XAMPP)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Manga {
  id          String    @id // MangaDex UUID or internal ID
  slug        String    @unique @db.VarChar(255)
  title       String    @db.Text
  description String?   @db.Text
  coverUrl    String?   @db.Text
  status      String?   // Ongoing, Completed
  author      String?
  source      String    @default("MangaDex") // Track source (MangaDex or Scraped)
  chapters    Chapter[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Chapter {
  id        String   @id @default(uuid())
  number    String
  title     String?
  mangaId   String
  manga     Manga    @relation(fields: [mangaId], references: [id])
  pages     Page[]
  sourceUrl String?  @db.Text
  lang      String   @default("vi")
  createdAt DateTime @default(now())
}

model Page {
  id         String  @id @default(uuid())
  number     Int
  imageUrl   String  @db.Text // URL to source or R2
  storageKey String? // Key for Cloudflare R2
  chapterId  String
  chapter    Chapter @relation(fields: [chapterId], references: [id])
}
